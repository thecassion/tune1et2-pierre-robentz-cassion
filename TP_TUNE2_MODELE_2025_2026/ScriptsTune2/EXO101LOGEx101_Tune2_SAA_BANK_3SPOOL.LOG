SQL> -- suppression des indexes posés dans le EXO91
SQL> 
SQL> declare
  2  
  3  sql_stmt	     varchar2(200);
  4  cursor c1 is
  5  	     select index_name
  6  	     from user_indexes
  7  	     where table_name in ('CLIENT',  'COMPTE',	'TRANSACTION')
  8  	     and
  9  	     (UNIQUENESS = 'NONUNIQUE'
 10  		     OR
 11  		     (UNIQUENESS='UNIQUE'
 12  			     and index_name not in (
 13  			     select constraint_name
 14  			     from user_constraints
 15  			     where constraint_type
 16  			     IN ('P', 'U')
 17  			     )
 18  		     )
 19  	     );
 20  begin
 21  	     for C1_elem in c1
 22  	     loop
 23  		     sql_stmt:= 'drop index ' || c1_elem.index_name;
 24  		     EXECUTE IMMEDIATE sql_stmt;
 25  	     end loop;
 26  
 27  end;
 28  /

