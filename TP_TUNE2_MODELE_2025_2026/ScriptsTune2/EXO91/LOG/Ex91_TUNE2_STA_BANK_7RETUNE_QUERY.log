SQL> 
SQL> -- Prendre un premier clich’┐Į AWR pour d’┐Įlimiter
SQL> -- l'espace de r’┐Įcup’┐Įration des requ’┐Įtes.
SQL> set serveroutput on
SQL> variable snapid1 number;
SQL> 
SQL> begin
  2  	     :snapid1	     := dbms_workload_repository.create_snapshot;
  3  	     dbms_output.put_line('snap_id1='||:snapid1);
  4  end;
  5  /
SP2-0640: Not connected
Help: https://docs.oracle.com/error-help/db/sp2-0640/
SQL> 
SQL> -- ReConnexion ’┐Į la  PDB pour utiliser STA
SQL> connect &MYPDBUSER@&DBALIASPDB/&MYPDBUSERPASS
Connected.
SQL> 
